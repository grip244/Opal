<Page
    x:Class="Opal.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="SettingsHeader.FontSize" Value="20" />
                        <Setter Target="AccountUserText.FontSize" Value="18" />
                        <Setter Target="AvatarContainer.Width" Value="48" />
                        <Setter Target="AvatarContainer.Height" Value="48" />
                        <Setter Target="RootScroll.Padding" Value="48,40,48,48" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ScrollViewer x:Name="RootScroll" Padding="40" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="32" MaxWidth="800" HorizontalAlignment="Left">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
                <TextBlock x:Name="SettingsHeader" Text="Settings" FontSize="28" FontWeight="Bold" Margin="0,0,0,12" Foreground="{ThemeResource AppTextForegroundBrush}"/>


                <StackPanel Spacing="16">
                    <TextBlock Text="Playback" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="{ThemeResource AppControlBackgroundBrush}" Padding="24" CornerRadius="8">
                        <StackPanel Spacing="12">
                            <ToggleSwitch x:Name="AutoPlayToggle" Header="Auto-Play" 
                                          Toggled="OnAutoPlayToggled" IsOn="True" UseSystemFocusVisuals="True"/>
                            <TextBlock Text="Automatically fetch and play random songs when the current queue ends." 
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap" Margin="0,-4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="16">
                    <TextBlock Text="Equalizer" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                    <Border Background="{ThemeResource AppControlBackgroundBrush}" BorderBrush="{ThemeResource AppControlBorderBrush}" BorderThickness="1" Padding="24" CornerRadius="12">
                        <StackPanel Spacing="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch x:Name="EqToggle" Header="DSP &amp; Equalizer" Toggled="OnEqToggled" UseSystemFocusVisuals="True"/>
                                <ComboBox x:Name="EqPresetsCombo" Grid.Column="1" Header="Preset" Width="200" 
                                          SelectionChanged="OnEqPresetSelected" VerticalAlignment="Bottom" UseSystemFocusVisuals="True">
                                    <ComboBoxItem Content="Flat" />
                                    <ComboBoxItem Content="Rock" />
                                    <ComboBoxItem Content="Electronic" />
                                    <ComboBoxItem Content="Acoustic" />
                                    <ComboBoxItem Content="Vocal" />
                                    <ComboBoxItem Content="R&amp;B" />
                                    <ComboBoxItem Content="Hip Hop" />
                                    <ComboBoxItem Content="Country" />
                                    <ComboBoxItem Content="Custom" IsEnabled="True" />
                                </ComboBox>
                            </Grid>

                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Pre-Amp" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                                    <TextBlock x:Name="EqPreAmpValue" Text="0.0 dB" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.8"/>
                                </Grid>
                                <Slider x:Name="EqPreAmpSlider" Minimum="-12" Maximum="12" StepFrequency="0.5" 
                                        Value="0" ValueChanged="OnEqPreAmpChanged" UseSystemFocusVisuals="True"/>
                            </StackPanel>

                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled">
                                <StackPanel Orientation="Horizontal" Spacing="16" Height="200">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue0" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider0" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="32Hz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue1" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider1" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="64Hz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue2" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider2" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="125Hz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue3" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider3" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="250Hz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue4" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider4" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="500Hz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue5" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider5" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="1kHz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue6" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider6" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="2kHz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue7" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider7" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="4kHz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue8" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider8" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="8kHz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="EqValue9" Text="0.0" FontSize="9" HorizontalAlignment="Center" Opacity="0.6"/>
                                        <Slider x:Name="EqSlider9" Orientation="Vertical" Minimum="-12" Maximum="12" StepFrequency="0.5" Height="150" ValueChanged="OnEqBandChanged" UseSystemFocusVisuals="True"/>
                                        <TextBlock Text="16kHz" FontSize="10" HorizontalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                            <TextBlock Text="Audio processing is handled in a separate thread for low latency." FontSize="11" Opacity="0.4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="16">
                    <TextBlock Text="Account" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                    <Border Background="{ThemeResource AppControlBackgroundBrush}" BorderBrush="{ThemeResource AppControlBorderBrush}" BorderThickness="1" Padding="24" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- User Avatar Icon -->
                            <Border x:Name="AvatarContainer" Width="64" Height="64" CornerRadius="32" Background="{ThemeResource SystemAccentColor}" Margin="0,0,20,0">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;" FontSize="32" Foreground="White" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock x:Name="AccountUserText" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.6">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE83B;" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                    <TextBlock x:Name="AccountServerText" FontSize="14" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" Content="Logout" Click="OnLogoutClicked" 
                                    Foreground="#FFFF4444" BorderBrush="#33FF4444" BorderThickness="1"
                                    Background="Transparent" Padding="24,8" CornerRadius="20" 
                                    VerticalAlignment="Center" UseSystemFocusVisuals="True"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 3.1: Controller & Keyboard Reference Card -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Shortcuts &amp; Controls" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                    <Border Background="{ThemeResource AppControlBackgroundBrush}" BorderBrush="{ThemeResource AppControlBorderBrush}" BorderThickness="1" Padding="24" CornerRadius="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Input Mapping Reference" FontSize="14" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,8" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Table Headers -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Xbox" FontSize="12" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,8" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Keyboard" FontSize="12" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,8" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Action" FontSize="12" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,8" Foreground="{ThemeResource AppTextForegroundBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="LB" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Prev Key" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Previous Track" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="RB" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Next Key" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Next Track" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="X" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Play/Pause Key" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Play / Pause" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Y" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Y" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="Focus Search Box" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="View (⧉)" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="None" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="Toggle Now Playing" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="LT" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="Vol Down" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="6" Grid.Column="2" Text="Volume Down" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="RT" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="Vol Up" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="7" Grid.Column="2" Text="Volume Up" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Menu (≡)" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,4"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="Enter" Opacity="0.6" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <TextBlock Grid.Row="8" Grid.Column="2" Text="Advance / Submit" Opacity="0.8" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                            </Grid>
                            <TextBlock Text="Custom button remapping coming in a future update." FontSize="11" Opacity="0.4" Margin="0,8,0,0" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="16">
                    <TextBlock Text="Legal" FontSize="20" FontWeight="SemiBold"/>
                    <Border Background="{ThemeResource AppControlBackgroundBrush}" Padding="24" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <HyperlinkButton Content="Privacy Policy" NavigateUri="https://darademsc.ddns.net/#privacy" Padding="0" UseSystemFocusVisuals="True"/>
                            <TextBlock Text="•" VerticalAlignment="Center" Opacity="0.4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                            <HyperlinkButton Content="Terms of Service" NavigateUri="https://darademsc.ddns.net/#tos" Padding="0" UseSystemFocusVisuals="True"/>
                            <TextBlock Text="•" VerticalAlignment="Center" Opacity="0.4" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                            <HyperlinkButton Content="GitHub Repository" NavigateUri="https://github.com/grip244/Opal" Padding="0" UseSystemFocusVisuals="True"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock Text="Opal v1.2.0" Opacity="0.4" HorizontalAlignment="Center" Margin="0,40,0,20" Foreground="{ThemeResource AppTextForegroundBrush}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
