<Page
    x:Class="Opal.PlaylistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:controls="using:Opal.UI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Opal.ViewModels"
    xmlns:models="using:Opal"
    xmlns:converters="using:Opal.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <Style x:Key="PlaylistItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0,0,16,24" />
        </Style>
        <Style x:Key="XboxPlaylistItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0,0,12,16" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}" Padding="24">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="48,40,48,48" />
                        <Setter Target="PageTitle.FontSize" Value="20" />
                        <Setter Target="PlaylistsGridView.Padding" Value="24,0,24,24" />
                        <Setter Target="PlaylistsGridView.ItemContainerStyle" Value="{StaticResource XboxPlaylistItemStyle}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,24">
            <StackPanel>
                <TextBlock x:Name="PageTitle" Text="Playlists" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                <TextBlock Text="Your personal collections" FontSize="14" Opacity="0.7" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" />
            </StackPanel>
            <Button x:Name="CreateButton" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnCreateNewClick" Style="{StaticResource AccentButtonStyle}" Padding="16,8" UseSystemFocusVisuals="True">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Add" />
                    <TextBlock Text="Create New" />
                </StackPanel>
            </Button>
        </Grid>

        <GridView x:Name="PlaylistsGridView" 
                  Grid.Row="1"
                  IsItemClickEnabled="True"
                  ItemClick="OnPlaylistClick"
                  ItemsSource="{x:Bind PlaylistsVM.Playlists, Mode=OneWay}"
                  ItemContainerStyle="{StaticResource PlaylistItemStyle}"
                  UseSystemFocusVisuals="True">
            <GridView.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20" />
                </TransitionCollection>
            </GridView.ItemContainerTransitions>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:PlaylistModel">
                    <StackPanel Width="160" Spacing="8">
                        <StackPanel.ContextFlyout>
                            <MenuFlyout>
                                 <MenuFlyoutItem Text="Edit Details" Click="OnEditPlaylistClick" Icon="Edit" />
                                <MenuFlyoutItem Text="Change Cover" Click="OnUploadCoverClick" Icon="Pictures" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Delete Playlist" Click="OnDeletePlaylistClick" Icon="Delete" />
                            </MenuFlyout>
                        </StackPanel.ContextFlyout>
                        <Border CornerRadius="12" Background="{ThemeResource AppControlBackgroundBrush}" Width="160" Height="160">
                            <Grid>
                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="300" />
                                <Grid Background="#33000000" Visibility="{Binding CoverUrl, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=reverse}" />
                                <SymbolIcon Symbol="MusicInfo" Foreground="White" Opacity="0.5" Width="48" Height="48" Visibility="{Binding CoverUrl, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=reverse}" />
                                
                                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Background="#88000000" BorderThickness="0" CornerRadius="14" Width="28" Height="28" Padding="0" Click="OnMoreButtonClicked" UseSystemFocusVisuals="True" Visibility="Visible">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" FontSize="12" Foreground="White" />
                                </Button>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.6">
                            <TextBlock Text="{Binding SongCount}" FontSize="12" Foreground="{ThemeResource AppTextForegroundBrush}" />
                            <TextBlock Text="tracks •" FontSize="12" Foreground="{ThemeResource AppTextForegroundBrush}" />
                            <TextBlock Text="{Binding Duration}" FontSize="12" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1" 
                    Visibility="{x:Bind PlaylistsVM.Playlists.Size, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='zero'}">
            <SymbolIcon Symbol="MusicInfo" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" Width="64" Height="64" Opacity="0.3" />
            <TextBlock Text="No playlists yet" FontSize="18" FontWeight="SemiBold" Opacity="0.5" Margin="0,12,0,0" Foreground="{ThemeResource AppTextForegroundBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Tap 'Create New' to get started" FontSize="14" Opacity="0.4" Margin="0,4,0,0" Foreground="{ThemeResource AppTextForegroundBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <muxc:ProgressRing IsActive="{x:Bind PlaylistsVM.IsLoading, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1" />
    </Grid>
</Page>
