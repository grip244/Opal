<Page
    x:Class="Opal.TracksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:controls="using:Opal.UI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="using:Opal.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AccentBrush" Color="#EE4040" />
            
            <converters:ExplicitStatusConverter x:Key="ExplicitStatusConverter" />
            <x:Double x:Key="HeaderFontSize">26</x:Double>
            <x:Double x:Key="ItemTitleFontSize">15</x:Double>
            <x:Double x:Key="ThumbSize">48</x:Double>
            <Thickness x:Key="ThumbMargin">12,0,0,0</Thickness>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24" Background="{ThemeResource AppBackgroundBrush}">


        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="48,40,48,48" />
                        <Setter Target="TracksListView.Padding" Value="24,0,24,24" />
                        <Setter Target="PageTitle.FontSize" Value="24" />
                        <Setter Target="FilterBox.Width" Value="180" />
                        <Setter Target="SortByCombo.Width" Value="130" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="16">
                    <TextBlock x:Name="PageTitle" Text="Tracks" FontSize="{StaticResource HeaderFontSize}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />
                    <Button Click="OnPlayAllClicked" Background="{ThemeResource SystemAccentColor}" Foreground="White" CornerRadius="16" Padding="16,6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Play"/>
                            <TextBlock Text="Play All" FontWeight="SemiBold" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="TotalTracksCounter" Text="Total Tracks: (Loading...)" FontSize="13" Opacity="0.6" VerticalAlignment="Center" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" />
                </StackPanel>


                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                    <Grid Width="220">
                        <TextBox x:Name="FilterBox" PlaceholderText="Search tracks..." 
                                 TextChanged="OnFilterOrSortChanged" 
                                 VerticalAlignment="Center" 
                                 Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" CornerRadius="18" Padding="32,6,12,6" />
                        <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.5" Foreground="{ThemeResource AppTextForegroundBrush}" />
                    </Grid>
                    
                    <!-- 3.3: Favorites Filter Toggle -->
                    <ToggleButton x:Name="FavoritesFilterBtn"
                                  Click="OnFavoritesFilterToggled"
                                  CornerRadius="16" Padding="14,6"
                                  VerticalAlignment="Center"
                                  XYFocusRight="{x:Bind SortByCombo}"
                                  XYFocusLeft="{x:Bind FilterBox}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" FontSize="14" />
                            <TextBlock Text="Liked" FontWeight="SemiBold" FontSize="13" />
                        </StackPanel>
                    </ToggleButton>
                    
                    <ComboBox x:Name="SortByCombo" Width="140" Height="36" SelectionChanged="OnFilterOrSortChanged" 
                              Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" CornerRadius="18" VerticalAlignment="Center">
                        <ComboBoxItem Content="A-Z (Title)" IsSelected="True" />
                        <ComboBoxItem Content="Artist" />
                        <ComboBoxItem Content="Duration" />
                    </ComboBox>
                </StackPanel>

            </Grid>

            <ListView x:Name="TracksListView" Grid.Row="1" ItemClick="OnTrackClicked" IsItemClickEnabled="True" 
                      SelectionMode="None" ShowsScrollingPlaceholders="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12" Margin="0,2" Background="{ThemeResource AppControlBackgroundBrush}" CornerRadius="12">
                            <Grid.ContextFlyout>
                                <MenuFlyout Opening="OnTrackContextOpening">
                                    <MenuFlyoutItem Text="Play" Click="OnPlayMenuClicked" Icon="Play" />
                                    <MenuFlyoutItem Text="Add to Queue" Click="OnAddQueueMenuClicked" Icon="Add" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutSubItem x:Name="AddToPlaylistMenu" Text="Add to Playlist..." Icon="List" />
                                    <MenuFlyoutItem x:Name="RemoveFromPlaylistMenu" Text="Remove from this Playlist" Click="OnRemoveFromPlaylistClicked" Icon="Delete" Visibility="Collapsed" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>

                            
                            <Border Grid.Column="0" CornerRadius="6" Width="{StaticResource ThumbSize}" Height="{StaticResource ThumbSize}" Background="{ThemeResource AppControlBackgroundBrush}">
                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="100" />
                            </Border>


                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="{StaticResource ThumbMargin}">

                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="{StaticResource ItemTitleFontSize}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}" />

                                    <Border Background="{ThemeResource AppTertiaryTextForegroundBrush}" CornerRadius="4" Padding="4,1" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                        <TextBlock Text="E" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource AppBackgroundBrush}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Artist}" FontSize="13" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" Opacity="0.8" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding Album}" FontSize="13" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" Opacity="0.6" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <ToggleButton Tag="{Binding}" IsChecked="{Binding IsFavorite, Mode=OneWay}" Click="OnTrackFavoriteClicked" Background="Transparent" Padding="4" BorderThickness="0" UseSystemFocusVisuals="True">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" Loaded="OnFavoriteIconLoaded" Tag="{Binding}" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                </ToggleButton>
                                <muxc:RatingControl MaxRating="5" Value="{Binding Rating, Mode=OneWay}" Tag="{Binding}" ValueChanged="OnTrackRatingChanged" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />
                            </StackPanel>

                            <TextBlock Grid.Column="4" Text="{Binding Duration}" FontSize="13" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" />

                            <Button Grid.Column="5" Background="Transparent" BorderThickness="0" UseSystemFocusVisuals="True" VerticalAlignment="Center" HorizontalAlignment="Center" Click="OnMoreButtonClicked" Width="36" Height="36" Padding="0" Visibility="Visible">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" FontSize="14" Foreground="{ThemeResource AppTextForegroundBrush}" Opacity="0.6" />
                            </Button>
                        </Grid>

                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.Footer>
                    <Grid Height="100">
                        <StackPanel x:Name="LoadingIndicator" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                            <muxc:ProgressRing IsActive="True" Width="20" Height="20" />
                            <TextBlock Text="Loading more tracks..." VerticalAlignment="Center" Opacity="0.6" />
                        </StackPanel>
                    </Grid>
                </ListView.Footer>
            </ListView>
        </Grid>
    </Grid>
</Page>
