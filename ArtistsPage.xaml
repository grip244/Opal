<Page
    x:Class="Opal.ArtistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:controls="using:Opal.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="ArtistItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="140" />
                <Setter Property="Margin" Value="10" />
            </Style>
            <Style x:Key="XboxArtistItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="110" />
                <Setter Property="Margin" Value="8" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24" Background="{ThemeResource AppBackgroundBrush}">


        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="48,40,48,48" />
                        <Setter Target="ArtistsGridView.Padding" Value="24,0,24,24" />
                        <Setter Target="ArtistsGridView.ItemContainerStyle" Value="{StaticResource XboxArtistItemStyle}" />
                        <Setter Target="PageTitle.FontSize" Value="20" />
                        <Setter Target="SearchContainer.Width" Value="160" />
                        <Setter Target="SortByCombo.Width" Value="110" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="PageTitle" Grid.Column="0" Text="Artists" FontSize="28" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Right" Spacing="16">
                    <Grid x:Name="SearchContainer" Width="220">
                        <TextBox x:Name="FilterBox" PlaceholderText="Search artists..."
                                 TextChanged="OnFilterOrSortChanged"
                                 VerticalAlignment="Center"
                                 Background="{ThemeResource AppControlBackgroundBrush}"
                                 BorderThickness="0" CornerRadius="18" Padding="32,6,12,6"
                                 UseSystemFocusVisuals="True"
                                 XYFocusRight="{x:Bind SortByCombo}" />
                        <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                  HorizontalAlignment="Left" Margin="12,0,0,0"
                                  VerticalAlignment="Center" Opacity="0.5"
                                  Foreground="{ThemeResource AppTextForegroundBrush}" />
                    </Grid>
                    <ComboBox x:Name="SortByCombo" Width="130" Height="36"
                              SelectionChanged="OnFilterOrSortChanged"
                              Background="{ThemeResource AppControlBackgroundBrush}"
                              BorderThickness="0" CornerRadius="18" VerticalAlignment="Center"
                              UseSystemFocusVisuals="True"
                              XYFocusLeft="{x:Bind FilterBox}">
                        <ComboBoxItem Content="A-Z" IsSelected="True" />
                        <ComboBoxItem Content="Album Count" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <GridView x:Name="ArtistsGridView" Grid.Row="1" ItemClick="OnArtistClicked" IsItemClickEnabled="True" ItemContainerStyle="{StaticResource ArtistItemStyle}" UseSystemFocusVisuals="True">
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20" />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="6">
                            <Grid Width="100" Height="100">
                                <Border CornerRadius="50" Background="{ThemeResource AppControlBackgroundBrush}">
                                    <controls:ThumbnailView SourceUrl="{Binding CoverUrl}"
                                                            DecodeWidth="200"
                                                            ThumbnailCornerRadius="50,50,50,50" />
                                </Border>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Background="{ThemeResource SystemAccentColor}" 
                                        CornerRadius="10" MinWidth="20" Height="20" Padding="6,0">
                                    <TextBlock Text="{Binding AlbumCount}" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" Margin="0,10,0,0" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
