<Page
    x:Class="Opal.ArtistsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="ArtistItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="140" />
                <Setter Property="Margin" Value="10" />
            </Style>
            <Style x:Key="XboxArtistItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="110" />
                <Setter Property="Margin" Value="8" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24" Background="{ThemeResource AppBackgroundBrush}">


        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="48,40,48,48" />
                        <Setter Target="ArtistsGridView.Padding" Value="24,0,24,24" />
                        <Setter Target="ArtistsGridView.ItemContainerStyle" Value="{StaticResource XboxArtistItemStyle}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Left" Margin="0,0,0,32" Spacing="16">
                <TextBlock Text="Artists" FontSize="26" FontWeight="Bold" HorizontalAlignment="Left" Foreground="{ThemeResource AppTextForegroundBrush}" SelectionChanged="TextBlock_SelectionChanged" />
            </StackPanel>

            <GridView x:Name="ArtistsGridView" Grid.Row="1" ItemClick="OnArtistClicked" IsItemClickEnabled="True" ItemContainerStyle="{StaticResource ArtistItemStyle}">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="6">
                            <Ellipse Width="100" Height="100">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding CoverArt}" Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" Margin="0,10,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
