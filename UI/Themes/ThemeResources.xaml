<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0A1A" Offset="0" />
                <GradientStop Color="#101025" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AppTextForegroundBrush" Color="White" />
            <SolidColorBrush x:Key="AppSecondaryTextForegroundBrush" Color="White" Opacity="0.7" />
            <SolidColorBrush x:Key="AppTertiaryTextForegroundBrush" Color="White" Opacity="0.5" />
            
            <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="White" Opacity="0.1" />
            <SolidColorBrush x:Key="AppControlBorderBrush" Color="White" Opacity="0.2" />
            
            <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="Black" Opacity="0.82" />
            
            <!-- Shimmer Effect Colors -->
            <Color x:Key="ShimmerBaseColor">#1A1A2E</Color>
            <Color x:Key="ShimmerHighlightColor">#2A2A48</Color>
            
            <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource ShimmerBaseColor}" Offset="0" x:Name="Stop1" />
                <GradientStop Color="{StaticResource ShimmerHighlightColor}" Offset="0.5" x:Name="Stop2" />
                <GradientStop Color="{StaticResource ShimmerBaseColor}" Offset="1" x:Name="Stop3" />
            </LinearGradientBrush>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F3F3F7" Offset="0" />
                <GradientStop Color="#E8E8F0" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="AppTextForegroundBrush" Color="Black" />
            <SolidColorBrush x:Key="AppSecondaryTextForegroundBrush" Color="Black" Opacity="0.8" />
            <SolidColorBrush x:Key="AppTertiaryTextForegroundBrush" Color="Black" Opacity="0.65" />


            <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="Black" Opacity="0.08" />
            <SolidColorBrush x:Key="AppControlBorderBrush" Color="Black" Opacity="0.15" />


            <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="White" Opacity="0.9" />

            <!-- Shimmer Effect Colors -->
            <Color x:Key="ShimmerBaseColor">#E0E0E6</Color>
            <Color x:Key="ShimmerHighlightColor">#EDEDF5</Color>

            <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource ShimmerBaseColor}" Offset="0" />
                <GradientStop Color="{StaticResource ShimmerHighlightColor}" Offset="0.5" />
                <GradientStop Color="{StaticResource ShimmerBaseColor}" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppTextForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppSecondaryTextForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTertiaryTextForegroundBrush" Color="{ThemeResource SystemColorWindowTextColor}" />

            <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AppControlBorderBrush" Color="{ThemeResource SystemColorButtonTextColor}" />

            <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
