<Page
    x:Class="Opal.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:controls="using:Opal.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:Opal"
    xmlns:converters="using:Opal.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource AppBackgroundBrush}">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />

            <!-- Sidebar blending overrides -->
            <SolidColorBrush x:Key="NavigationViewSeparatorBrush" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
        </ResourceDictionary>
    </Page.Resources>
    
    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="MainNavigationView.PaneDisplayMode" Value="LeftCompact" />
                        <Setter Target="MainNavigationView.IsPaneToggleButtonVisible" Value="False" />
                        <Setter Target="MainNavigationView.PaneBackground" Value="Transparent" />
                        <Setter Target="MainNavigationView.Background" Value="Transparent" />
                        <Setter Target="MainNavigationView.BorderThickness" Value="0" />
                        <Setter Target="MainNavigationView.CompactPaneLength" Value="60" />
                        
                        <!-- Floating Pill Player Bar - Centered & Elevated -->
                        <Setter Target="GlobalPlayerBar.(Grid.RowSpan)" Value="2" />
                        <Setter Target="GlobalPlayerBar.(Grid.Row)" Value="0" />
                        <Setter Target="GlobalPlayerBar.VerticalAlignment" Value="Bottom" />
                        <Setter Target="GlobalPlayerBar.HorizontalAlignment" Value="Center" />
                        <Setter Target="GlobalPlayerBar.Margin" Value="0,0,0,24" />
                        <Setter Target="MainNavigationView.IsSettingsVisible" Value="True" />
                        <Setter Target="GlobalPlayerBar.Height" Value="100" />
                        <Setter Target="GlobalPlayerBar.Width" Value="800" />
                        <Setter Target="GlobalPlayerBar.CornerRadius" Value="50" />
                        <Setter Target="GlobalPlayerBar.BorderThickness" Value="1" />
                        <Setter Target="GlobalPlayerBar.Background" Value="#11000000" />
                        
                        <Setter Target="MiniThumbnailBorder.Width" Value="100" />
                        <Setter Target="MiniThumbnailBorder.Height" Value="100" />
                        <Setter Target="MiniThumbnailBorder.CornerRadius" Value="50,0,0,50" />
                        <Setter Target="MiniThumbnailBorder.Margin" Value="0" />
                        <Setter Target="MiniThumbnail.ThumbnailCornerRadius" Value="50,0,0,50" />
                        
                        <Setter Target="NowPlayingTitle.FontSize" Value="15" />
                        <Setter Target="NowPlayingArtist.FontSize" Value="12" />
                        <Setter Target="InfoColumn.Width" Value="260" />
                        <Setter Target="TitleContainer.MaxWidth" Value="130" />
                        
                        <Setter Target="TransportControls.Spacing" Value="20" />
                        <Setter Target="PlayPauseButton.Width" Value="64" />
                        <Setter Target="PlayPauseButton.Height" Value="64" />
                        <Setter Target="PlayPauseButton.Margin" Value="0,0,0,0" />
                        <Setter Target="PlayPauseIcon.Scale" Value="1.2,1.2,1" />
                        
                        <Setter Target="FavoriteBtn.Visibility" Value="Visible" />
                        <Setter Target="GlobalRatingControl.Visibility" Value="Visible" />
                        <Setter Target="GlobalRatingControl.Scale" Value="0.4,0.4,1" />
                        <Setter Target="GlobalRatingControl.Margin" Value="0,0,0,0" />
                        <Setter Target="FavoriteIcon.FontSize" Value="14" />
                        <Setter Target="FavoriteBtn.Padding" Value="0" />
                        <Setter Target="CurrentTimeText.Visibility" Value="Visible" />
                        <Setter Target="TotalTimeText.Visibility" Value="Visible" />
                        
                        <!-- Progress Slider - Visible & System Themed -->
                        <Setter Target="ProgressSlider.VerticalAlignment" Value="Center" />
                        <Setter Target="ProgressSlider.Margin" Value="12,0,12,0" />
                        <Setter Target="ProgressSlider.Height" Value="32" />
                        <Setter Target="ProgressSlider.Foreground" Value="{ThemeResource SystemAccentColor}" />
                        
                        <Setter Target="VolumeSlider.Visibility" Value="Visible" />
                        <Setter Target="CastButton.Visibility" Value="Collapsed" />
                        <Setter Target="SearchBox.Visibility" Value="Collapsed" />
                        <Setter Target="XboxSearchItem.Visibility" Value="Visible" />
                        <Setter Target="PlaylistsNavItem.Visibility" Value="Collapsed" />
                        <Setter Target="PlaylistsSeparator.Visibility" Value="Collapsed" />
                        <Setter Target="PlayerExplicitBadge.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Xbox Search Overlay -->
        <Grid x:Name="XboxSearchOverlay" VerticalAlignment="Top" Height="80" Visibility="Collapsed" Canvas.ZIndex="1000" Background="{ThemeResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Background="#CC000000" Grid.RowSpan="2" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <AutoSuggestBox x:Name="XboxSearchBox" 
                                Width="600" 
                                PlaceholderText="Search music..." 
                                QueryIcon="Find"
                                TextChanged="OnSearchTextChanged"
                                SuggestionChosen="OnSearchSuggestionChosen"
                                QuerySubmitted="OnSearchEntered"
                                XYFocusDown="{x:Bind ContentFrame}">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Padding="4">
                                <Grid Width="40" Height="40" Margin="0,0,12,0">
                                    <Border Background="#33FFFFFF" CornerRadius="4">
                                        <FontIcon Glyph="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border CornerRadius="4">
                                        <controls:ThumbnailView SourceUrl="{Binding ImageUrl}" DecodeWidth="80" />
                                    </Border>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
                <Button x:Name="CloseSearchBtn" Content="Close" Click="OnCloseSearchClick" CornerRadius="18" Padding="16,8" Background="Transparent" BorderThickness="1" BorderBrush="White" />
            </StackPanel>
            <Border Height="1" Background="{ThemeResource SystemAccentColor}" VerticalAlignment="Bottom" Opacity="0.5" Grid.Row="1" />
        </Grid>



        <muxc:NavigationView x:Name="MainNavigationView"
                           PaneDisplayMode="Left"
                           OpenPaneLength="240"
                           IsPaneToggleButtonVisible="True"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="True"
                           ItemInvoked="OnMenuItemInvoked">
            <muxc:NavigationView.AutoSuggestBox>
                <AutoSuggestBox x:Name="SearchBox" 
                                PlaceholderText="Search music..." 
                                QueryIcon="Find"
                                TextChanged="OnSearchTextChanged"
                                SuggestionChosen="OnSearchSuggestionChosen"
                                QuerySubmitted="OnSearchEntered">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Padding="4">
                                <Grid Width="40" Height="40" Margin="0,0,12,0">
                                    <Border Background="#33FFFFFF" CornerRadius="4">
                                        <FontIcon Glyph="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border CornerRadius="4">
                                        <controls:ThumbnailView SourceUrl="{Binding ImageUrl}" DecodeWidth="80" />
                                    </Border>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
            </muxc:NavigationView.AutoSuggestBox>
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Library" Tag="Library" Icon="Home" />
                <muxc:NavigationViewItem Content="Artists" Tag="Artists" Icon="Contact" />
                <muxc:NavigationViewItem Content="Albums" Tag="Albums" Icon="AllApps" />
                <muxc:NavigationViewItem Content="Tracks" Tag="Tracks" Icon="Audio" />
                <muxc:NavigationViewItem Content="Genres" Tag="Genres" Icon="Tag" />
                <muxc:NavigationViewItem x:Name="XboxSearchItem" Tag="Search" Icon="Find" Content="Search" Visibility="Collapsed" />
                <muxc:NavigationViewItemSeparator x:Name="PlaylistsSeparator" />
                <muxc:NavigationViewItem x:Name="PlaylistsNavItem" Tag="Playlists" SelectsOnInvoked="False" IsExpanded="True">
                    <muxc:NavigationViewItem.Content>
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,28,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Playlists" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Click="OnNewPlaylistClick" Background="Transparent" BorderThickness="0" Width="32" Height="32" Padding="0">
                                    <SymbolIcon Symbol="Add" />
                                </Button>
                                <Button Click="OnViewPlaylistsClick" Background="Transparent" BorderThickness="0" Width="32" Height="32" Padding="0">
                                    <SymbolIcon Symbol="List" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </muxc:NavigationViewItem.Content>
                </muxc:NavigationViewItem>
                <!-- Dynamic playlists will be inserted after this item -->
            </muxc:NavigationView.MenuItems>
            <muxc:NavigationView.PaneFooter>
            </muxc:NavigationView.PaneFooter>
            
            <Frame x:Name="ContentFrame" Navigated="OnNavigated" Padding="0" />
        </muxc:NavigationView>

        <!-- Global Player Bar -->
        <Border x:Name="GlobalPlayerBar" Grid.Row="1" Background="#11000000" BorderBrush="{ThemeResource AppControlBorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0" Height="112" Margin="0" Padding="0" Visibility="Collapsed">
            <Border.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="112" />
                </TransitionCollection>
            </Border.Transitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="InfoColumn" Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Canvas x:Name="PlayerBarBackgroundCanvas" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="MiniThumbnailBorder" Background="#22FFFFFF" Width="112" Height="112" CornerRadius="0" PointerEntered="OnThumbnailPointerEntered" PointerExited="OnThumbnailPointerExited">
                        <Grid>
                            <controls:ThumbnailView x:Name="MiniThumbnail" DecodeWidth="200" IsHitTestVisible="False" ThumbnailCornerRadius="0" />
                            <Button x:Name="ExpandThumbnailButton" Content="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="20" Background="#99000000" Foreground="White" Width="112" Height="112" Visibility="Collapsed" BorderThickness="0" CornerRadius="0" IsHitTestVisible="True" Click="OnThumbnailClicked" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="24,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Grid x:Name="TitleContainer" MaxWidth="180" Height="28" VerticalAlignment="Center">
                                <Grid.Clip>
                                    <RectangleGeometry x:Name="TitleClip" />
                                </Grid.Clip>
                                <ScrollViewer HorizontalScrollBarVisibility="Hidden" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden" VerticalScrollMode="Disabled" Padding="0" Margin="0">
                                    <TextBlock x:Name="NowPlayingTitle" Text="Not Playing" FontSize="18" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" SizeChanged="OnTitleSizeChanged" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="None">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="TitleScrollTransform" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </ScrollViewer>
                            </Grid>
                            <Border x:Name="PlayerExplicitBadge" Visibility="Collapsed" Background="{ThemeResource AppTertiaryTextForegroundBrush}" CornerRadius="3" Padding="4,2" VerticalAlignment="Center">
                                <TextBlock Text="E" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource AppBackgroundBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="NowPlayingArtist" Text="Disconnected" FontSize="13" Opacity="0.7" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                            <ToggleButton x:Name="FavoriteBtn" Background="Transparent" Padding="4" VerticalAlignment="Center" Click="OnFavoriteClicked" ToolTipService.ToolTip="Favorite">
                                <FontIcon x:Name="FavoriteIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" />
                            </ToggleButton>
                            <muxc:RatingControl x:Name="GlobalRatingControl" MaxRating="5" ValueChanged="OnGlobalRatingChanged" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,24,0" VerticalAlignment="Center">
                    <StackPanel.Transitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="40" />
                        </TransitionCollection>
                    </StackPanel.Transitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeText" Text="0:00" FontSize="14" Opacity="0.6" Margin="0,0,12,0" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        <Slider x:Name="ProgressSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0" ThumbToolTipValueConverter="{StaticResource TimeSpanToStringConverter}" PointerCaptureLost="OnProgressSeek" />
                        <TextBlock x:Name="TotalTimeText" Text="0:00" Grid.Column="2" FontSize="14" Opacity="0.6" Margin="12,0,0,0" Foreground="{ThemeResource AppTextForegroundBrush}" />
                    </Grid>

                    <StackPanel x:Name="TransportControls" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                        <!-- 3.2: Shuffle Toggle -->
                        <ToggleButton x:Name="ShuffleBtn" Click="OnShuffleClicked"
                                      Background="Transparent" Padding="10"
                                      ToolTipService.ToolTip="Shuffle"
                                      UseSystemFocusVisuals="True"
                                      XYFocusRight="{x:Bind PrevButton}">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B1;" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" x:Name="ShuffleIcon" />
                        </ToggleButton>
                        <Button x:Name="PrevButton" Click="OnPreviousClicked" Background="Transparent" Padding="12" UseSystemFocusVisuals="True">
                            <SymbolIcon Symbol="Previous" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        </Button>
                        <Button x:Name="PlayPauseButton" Click="OnPlayPauseClicked" Width="56" Height="56" CornerRadius="28" Background="{ThemeResource SystemAccentColor}" Foreground="{ThemeResource AppTextForegroundBrush}" UseSystemFocusVisuals="True">
                            <SymbolIcon x:Name="PlayPauseIcon" Symbol="Play" Scale="1.1,1.1,1" />
                        </Button>
                        <Button x:Name="NextButton" Click="OnNextClicked" Background="Transparent" Padding="12" UseSystemFocusVisuals="True">
                            <SymbolIcon Symbol="Next" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        </Button>
                        <!-- 3.2: Repeat Toggle -->
                        <Button x:Name="RepeatBtn" Click="OnRepeatClicked"
                                Background="Transparent" Padding="10"
                                ToolTipService.ToolTip="Repeat"
                                UseSystemFocusVisuals="True"
                                XYFocusLeft="{x:Bind NextButton}">
                            <FontIcon x:Name="RepeatIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE8EE;" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        </Button>
                        <Button x:Name="LyricsButton" Click="OnLyricsToggleClicked" Background="Transparent" Padding="12" ToolTipService.ToolTip="Lyrics Toggle" UseSystemFocusVisuals="True">
                            <SymbolIcon Symbol="Microphone" Foreground="{ThemeResource AppTextForegroundBrush}" />
                        </Button>
                        <Button x:Name="CastButton" Background="Transparent" Padding="12" ToolTipService.ToolTip="Casting Active" UseSystemFocusVisuals="True">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEC15;" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                            <Button.Flyout>
                                <Flyout x:Name="CastFlyout" Opened="OnCastFlyoutOpened">
                                    <StackPanel Spacing="10" Width="250">
                                        <TextBlock Text="Cast to Device" Style="{StaticResource BaseTextBlockStyle}" FontWeight="Bold"/>
                                        
                                        <TextBlock Text="Discovered Devices:" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                        <ListView x:Name="DiscoveredDevicesList" Height="150" SelectionMode="Single" SelectionChanged="OnDeviceSelected">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,5">
                                                        <SymbolIcon Symbol="Remote" />
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <MenuFlyoutSeparator />
                                        <TextBlock Text="Manual IP Fallback:" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                        <TextBox x:Name="TargetIPBox" PlaceholderText="Target IP (e.g. 192.168.1.5)" InputScope="Number"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                                            <Button x:Name="DisconnectButton" Content="Disconnect" Click="OnDisconnectClicked" Visibility="Collapsed" />
                                            <Button Content="Cast Now" Click="OnCastNowClicked" Style="{StaticResource AccentButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <!-- 3.4: Sleep Timer -->
                        <Button x:Name="SleepTimerBtn" Background="Transparent" Padding="10"
                                ToolTipService.ToolTip="Sleep Timer"
                                UseSystemFocusVisuals="True">
                            <FontIcon x:Name="SleepTimerIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE708;" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" />
                            <Button.Flyout>
                                <MenuFlyout x:Name="SleepTimerFlyout">
                                    <MenuFlyoutItem x:Name="Sleep15" Text="Sleep in 15 min" Click="OnSleepTimerClicked" Tag="15" />
                                    <MenuFlyoutItem x:Name="Sleep30" Text="Sleep in 30 min" Click="OnSleepTimerClicked" Tag="30" />
                                    <MenuFlyoutItem x:Name="Sleep60" Text="Sleep in 60 min" Click="OnSleepTimerClicked" Tag="60" />
                                    <MenuFlyoutItem x:Name="Sleep90" Text="Sleep in 90 min" Click="OnSleepTimerClicked" Tag="90" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="SleepCancel" Text="Cancel" Click="OnSleepTimerCancelClicked" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button x:Name="VolumeBtn" Background="Transparent" Padding="12" BorderThickness="0" UseSystemFocusVisuals="True">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE767;" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" />
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Height="160" Padding="10" Spacing="8">
                                        <TextBlock x:Name="VolumeText" Text="100" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        <Slider x:Name="VolumeSlider" Orientation="Vertical" Minimum="0" Maximum="100" Value="100" ValueChanged="OnVolumeChanged" HorizontalAlignment="Center" UseSystemFocusVisuals="True" Height="110" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
