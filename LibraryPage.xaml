<Page
    x:Class="Opal.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Opal.Converters"
    xmlns:controls="using:Opal.UI.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <CollectionViewSource x:Key="AlbumSongsSource" IsSourceGrouped="True" ItemsPath="Items" />
            <x:Double x:Key="AlbumSize">140</x:Double>
            <x:Double x:Key="TitleFontSize">22</x:Double>
            <Thickness x:Key="PagePadding">24</Thickness>
            
            <Style x:Key="AlbumItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="150" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>
            <Style x:Key="XboxAlbumItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="120" />
                <Setter Property="Margin" Value="0,0,12,0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>
            
            <Style x:Key="XboxCinematicItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="140" />
                <Setter Property="Margin" Value="0,0,16,0" />
            </Style>

            <!-- Xbox Specific: Cinematic Wide Template -->
            <DataTemplate x:Key="XboxCinematicCardTemplate">
                <Grid x:Name="RootItem" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="FocusStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="BorderThickness" To="2" Duration="0:0:0.1" />
                                    <ColorAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="{ThemeResource SystemAccentColor}" Duration="0:0:0.1" />
                                </Storyboard>
                            </VisualState>
                            <VisualState x:Name="Focused">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="BorderThickness" To="2" Duration="0:0:0.1" />
                                    <ColorAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="{ThemeResource SystemAccentColor}" Duration="0:0:0.1" />
                                </Storyboard>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    
                    <StackPanel Spacing="6">
                        <Grid Height="68" Width="120">
                            <!-- Stacked Effect -->
                            <Border Margin="8,-4,-8,4" CornerRadius="4" Background="{ThemeResource AppControlBackgroundBrush}" Opacity="0.2" />
                            <Border Margin="4,-2,-4,2" CornerRadius="4" Background="{ThemeResource AppControlBackgroundBrush}" Opacity="0.4" />
                            
                            <Border x:Name="ArtBorder" CornerRadius="6" Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="1" BorderBrush="{ThemeResource AppControlBorderBrush}">
                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="400" />
                            </Border>
                        </Grid>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                            <TextBlock Text="{Binding Artist}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </DataTemplate>

            <!-- Xbox Specific: Stacked Album Template with Focus Animation -->
            <DataTemplate x:Key="XboxAlbumCardTemplate">
                <Grid x:Name="RootItem" Background="Transparent" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="FocusStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="BorderThickness" To="2" Duration="0:0:0.1" />
                                    <ColorAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="White" Duration="0:0:0.1" />
                                </Storyboard>
                            </VisualState>
                            <VisualState x:Name="Focused">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="BorderThickness" To="2" Duration="0:0:0.1" />
                                    <ColorAnimation Storyboard.TargetName="ArtBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="White" Duration="0:0:0.1" />
                                </Storyboard>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    
                    <StackPanel Spacing="6">
                        <!-- Stacked Layers Effect -->
                        <Grid Height="60" Width="60">
                            <!-- Bottom Layer -->
                            <Border Margin="4,-3,-4,3" CornerRadius="4" Background="{ThemeResource AppControlBackgroundBrush}" Opacity="0.2" BorderThickness="1" BorderBrush="{ThemeResource AppControlBorderBrush}"/>
                            <!-- Middle Layer -->
                            <Border Margin="2,-1,-2,1" CornerRadius="5" Background="{ThemeResource AppControlBackgroundBrush}" Opacity="0.4" BorderThickness="1" BorderBrush="{ThemeResource AppControlBorderBrush}"/>
                            
                            <!-- Main Art Border -->
                            <Border x:Name="ArtBorder" CornerRadius="8" Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="1" BorderBrush="{ThemeResource AppControlBorderBrush}">
                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="200" />
                            </Border>
                        </Grid>

                        <StackPanel Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                                <Border Background="{ThemeResource AppTertiaryTextForegroundBrush}" CornerRadius="3" Padding="3,1" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                    <TextBlock Text="E" FontSize="8" FontWeight="Bold" Foreground="{ThemeResource AppBackgroundBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Artist}" FontSize="10" Opacity="0.6" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </DataTemplate>

            <Style x:Key="HiddenFlipViewButtonsStyle" TargetType="FlipView">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="FlipView">
                            <Grid Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="ScrollingHost" AutomationProperties.AccessibilityView="Raw" HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}" HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}" IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}" IsHorizontalRailEnabled="{TemplateBinding ScrollViewer.IsHorizontalRailEnabled}" IsVerticalRailEnabled="{TemplateBinding ScrollViewer.IsVerticalRailEnabled}" VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}" VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}" ZoomMode="{TemplateBinding ScrollViewer.ZoomMode}">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <converters:ExplicitStatusConverter x:Key="ExplicitStatusConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

            <DataTemplate x:Key="AlbumCardTemplate">
                <StackPanel Spacing="6">
                    <Border x:Name="ArtBorder" CornerRadius="8" Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="1" BorderBrush="{ThemeResource AppControlBorderBrush}" Height="{StaticResource AlbumSize}" Width="{StaticResource AlbumSize}">
                        <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="200" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}"/>
                        <Border Background="{ThemeResource AppTertiaryTextForegroundBrush}" CornerRadius="3" Padding="3,1" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                            <TextBlock Text="E" FontSize="8" FontWeight="Bold" Foreground="{ThemeResource AppBackgroundBrush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Artist}" FontSize="11" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}"/>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>
    
    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="BrowseGrid.Padding" Value="48,24,48,48" />
                        <Setter Target="HomeStack.Spacing" Value="20" />
                        <Setter Target="LibraryTitle.FontSize" Value="18" />
                        <Setter Target="NewestTitle.FontSize" Value="18" />
                        <Setter Target="RecentTitle.FontSize" Value="18" />
                        <Setter Target="RecentlyPlayedTitle.FontSize" Value="18" />
                        <!-- Cinematic Uniform Carousels -->
                        <Setter Target="ExploreGridView.ItemContainerStyle" Value="{StaticResource XboxCinematicItemStyle}" />
                        <Setter Target="ExploreGridView.ItemTemplate" Value="{StaticResource XboxCinematicCardTemplate}" />

                        <Setter Target="RecentlyPlayedGridView.ItemContainerStyle" Value="{StaticResource XboxCinematicItemStyle}" />
                        <Setter Target="RecentlyPlayedGridView.ItemTemplate" Value="{StaticResource XboxCinematicCardTemplate}" />

                        <Setter Target="NewlyAddedGridView.ItemContainerStyle" Value="{StaticResource XboxCinematicItemStyle}" />
                        <Setter Target="NewlyAddedGridView.ItemTemplate" Value="{StaticResource XboxCinematicCardTemplate}" />
                        
                        <Setter Target="RecentlyReleasedGridView.ItemContainerStyle" Value="{StaticResource XboxCinematicItemStyle}" />
                        <Setter Target="RecentlyReleasedGridView.ItemTemplate" Value="{StaticResource XboxCinematicCardTemplate}" />

                        <Setter Target="SpotlightHero.Visibility" Value="Collapsed" />
                        <Setter Target="XboxFeaturedCarousel.Visibility" Value="Visible" />
                        <Setter Target="XboxTopNav.Visibility" Value="Visible" />
                        
                        <Setter Target="LyricsListView.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="LyricsOverlay.Padding" Value="20" />
                        <Setter Target="QueuePanel.Margin" Value="0,24,40,140" />
                        <Setter Target="ArtistDetailName.FontSize" Value="30" />
                        <Setter Target="ArtistDetailImage.Width" Value="80" />
                        <Setter Target="ArtistDetailImage.Height" Value="80" />
                        <Setter Target="AlbumDetailImage.Width" Value="150" />
                        <Setter Target="AlbumDetailImage.Height" Value="150" />
                        <Setter Target="NowPlayingImageBorder.Width" Value="NaN" />
                        <Setter Target="NowPlayingImageBorder.Height" Value="NaN" />
                        <Setter Target="NowPlayingImageBorder.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="NowPlayingImageBorder.VerticalAlignment" Value="Stretch" />
                        <Setter Target="NowPlayingImageBorder.Margin" Value="0" />
                        <Setter Target="NowPlayingImage.ThumbnailCornerRadius" Value="0" />
                        <Setter Target="NowPlayingImage.DecodeWidth" Value="1500" />
                        <Setter Target="AlbumArtView.VerticalAlignment" Value="Stretch" />
                        <Setter Target="AlbumArtView.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="FullPlayerGrid.Background" Value="Transparent" />
                        <Setter Target="XboxHeader.Visibility" Value="Visible" />
                        <Setter Target="GenreGridItem.Width" Value="120" />
                        <Setter Target="GenreGridItem.Height" Value="70" />
                        <Setter Target="GenreGridText.FontSize" Value="12" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>


        <Grid x:Name="PlayerPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>


            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid x:Name="BrowseGrid" Visibility="Visible" Padding="{StaticResource PagePadding}">
                    <!-- HomeGrid, ArtistGrid, AlbumGrid -->
                    <Grid x:Name="HomeGrid" Visibility="Collapsed" d:Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="HomeStack" Spacing="32" Padding="0,0,0,40">
                                <StackPanel.ChildrenTransitions>
                                    <TransitionCollection>
                                        <EntranceThemeTransition FromVerticalOffset="20" />
                                    </TransitionCollection>
                                </StackPanel.ChildrenTransitions>
                                <!-- Xbox Top Navigation & Casting -->
                                <Grid x:Name="XboxHeader" Visibility="Collapsed" Margin="0,0,0,32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <ListView x:Name="XboxTopNav" SelectionMode="None" IsItemClickEnabled="True" 
                                              HorizontalAlignment="Left" BorderThickness="0" Padding="0">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="24" />
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.Items>
                                            <HyperlinkButton Content="Artists" Click="OnSeeAllArtists" FontSize="18" FontWeight="SemiBold" Opacity="0.6" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                            <HyperlinkButton Content="Albums" Click="OnSeeAllExplore" FontSize="18" FontWeight="SemiBold" Opacity="0.6" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                            <HyperlinkButton Content="Genres" Click="OnSeeAllGenres" FontSize="18" FontWeight="SemiBold" Opacity="0.6" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                            <HyperlinkButton Content="Playlists" Click="OnSeeAllPlaylists" FontSize="18" FontWeight="SemiBold" Opacity="0.6" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        </ListView.Items>
                                    </ListView>

                                    <Button x:Name="XboxCastButton" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="12" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEC15;" FontSize="16" />
                                            <TextBlock Text="Connect to device" FontSize="14" Opacity="0.8" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <Flyout Opened="OnCastFlyoutOpened">
                                                 <!-- Reuse cast content? Or just basic for now -->
                                                 <TextBlock Text="Searching for devices..." Padding="20" />
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>

                                <!-- Xbox Featured Carousel (Cinematic) -->
                                <FlipView x:Name="XboxFeaturedCarousel" Visibility="Collapsed" Height="220" Margin="24,0,24,16" 
                                          ItemsSource="{x:Bind LibraryVM.SpotlightSongs, Mode=OneWay}" 
                                          Style="{StaticResource HiddenFlipViewButtonsStyle}"
                                          Background="Transparent">
                                    <FlipView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Tapped="OnSpotlightTapped" Tag="{Binding}" Background="{ThemeResource AppControlBackgroundBrush}" CornerRadius="20">
                                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" IsBlurEnabled="True" />
                                                <Grid Background="#44000000" /> <!-- Darken -->
                                                <StackPanel VerticalAlignment="Center" Margin="60,0,0,0" Spacing="16">
                                                    <Border Background="{ThemeResource SystemAccentColor}" HorizontalAlignment="Left" Padding="8,4" CornerRadius="4">
                                                        <TextBlock Text="FEATURED" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <TextBlock Text="{Binding Artist}" FontSize="16" Opacity="0.8" Foreground="White" VerticalAlignment="Center" />
                                                        <Border Background="{ThemeResource AppControlBackgroundBrush}" Padding="8,3" CornerRadius="4" VerticalAlignment="Center" Visibility="{Binding Genre, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Genre}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                        </Border>
                                                        <Border Background="{ThemeResource AppControlBackgroundBrush}" Padding="8,3" CornerRadius="4" VerticalAlignment="Center" Visibility="{Binding Year, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding Year}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                                                        <Button Content="Play Now" Click="OnSpotlightTapped" Tag="{Binding}" Background="{ThemeResource SystemAccentColor}" Foreground="White" CornerRadius="20" Height="40" Padding="24,0" />
                                                        <Button Content="View Artist" Click="OnViewArtistClicked" Tag="{Binding ArtistId}" Background="Transparent" BorderBrush="White" BorderThickness="1" Foreground="White" CornerRadius="20" Height="40" Padding="24,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </FlipView.ItemTemplate>
                                </FlipView>

                                <!-- Spotlight Carousel (PC) -->
                                <Grid x:Name="SpotlightHero" Margin="0,0,0,12" Height="200">
                                    <FlipView x:Name="SpotlightCarousel" ItemsSource="{x:Bind LibraryVM.SpotlightSongs, Mode=OneWay}" SelectionChanged="OnCarouselSelectionChanged" Background="Transparent" Style="{StaticResource HiddenFlipViewButtonsStyle}">
                                        <FlipView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Tapped="OnSpotlightTapped" Tag="{Binding}" Background="#11FFFFFF" CornerRadius="12">
                                                     <!-- Stretched Background -->
                                                    <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" IsBlurEnabled="True" />
                                                    
                                                    <!-- Gradient Overlay for Legibility (Transparent -> Dark) -->
                                                    <Grid>
                                                        <Grid.Background>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Color="#00000000" Offset="0" />
                                                                <GradientStop Color="#CC000000" Offset="0.8" />
                                                                <GradientStop Color="#FF000000" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Grid.Background>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" Padding="24" Spacing="24" VerticalAlignment="Center">
                                                        <Border CornerRadius="8" Width="150" Height="150" BorderThickness="1" BorderBrush="#22FFFFFF" Background="#11FFFFFF" Canvas.ZIndex="1">
                                                            <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="150" />
                                                        </Border>
                                                         <StackPanel VerticalAlignment="Center" Spacing="0">
                                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Foreground="White" MaxLines="1" />
                                                                <Border Background="#55FFFFFF" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                                                    <TextBlock Text="E" FontSize="10" FontWeight="Bold" Foreground="White" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Artist}" FontSize="16" FontWeight="SemiBold" Opacity="0.9" Foreground="White" />
                                                            <TextBlock Text="{Binding Album}" FontSize="14" Opacity="0.6" Foreground="White" Margin="0,2,0,0" />
                                                            <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.4" Margin="0,8,0,0">
                                                                <TextBlock Text="{Binding Genre}" FontSize="14" Foreground="White" />
                                                                <TextBlock Text="•" FontSize="14" Foreground="White" />
                                                                <TextBlock Text="{Binding Year}" FontSize="14" Foreground="White" />
                                                            </StackPanel>
                                                        </StackPanel>

                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </FlipView.ItemTemplate>
                                    </FlipView>

                                    <!-- Arrows -->
                                    <Button x:Name="CarouselPrevBtn" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Background="#99111111" Width="42" Height="42" CornerRadius="21" BorderThickness="0" Click="OnCarouselPrev">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76B;" FontSize="14" Foreground="White" />
                                    </Button>
                                    <Button x:Name="CarouselNextBtn" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Background="#99111111" Width="42" Height="42" CornerRadius="21" BorderThickness="0" Click="OnCarouselNext">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="14" Foreground="White" />
                                    </Button>
                                </Grid>

                                <!-- Recommended Genres -->
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <TextBlock Text="Recommended Genres" FontSize="20" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        <HyperlinkButton Content="See All →" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnSeeAllGenres" FontSize="13" Opacity="0.8" UseSystemFocusVisuals="True" />
                                    </Grid>
                                    <GridView x:Name="FeaturedGenresGrid"
                                              SelectionMode="None"
                                              IsItemClickEnabled="True"
                                              ItemClick="OnGenreClicked"
                                              Padding="0,4"
                                              ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled">
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="1" />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid x:Name="GenreGridItem" Width="160" Height="90" Margin="0,0,12,0">
                                                    <Border CornerRadius="12" Background="{Binding BackgroundColor}" BorderThickness="1" BorderBrush="#11FFFFFF">
                                                        <Grid Padding="16">
                                                            <TextBlock x:Name="GenreGridText" Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="White" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis" />
                                                            <SymbolIcon Symbol="Audio" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.2" Foreground="White" />
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>


                                <!-- Explore from your library -->
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <TextBlock x:Name="LibraryTitle" Text="Explore From Your Library" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        <HyperlinkButton Content="See All →" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnSeeAllExplore" FontSize="13" Opacity="0.8" UseSystemFocusVisuals="True" />
                                    </Grid>
                                    <GridView x:Name="ExploreGridView" ItemClick="OnGenericAlbumClicked" IsItemClickEnabled="True" SelectionMode="None" 
                                              HorizontalAlignment="Stretch" VerticalAlignment="Top" Padding="0,0,0,8"
                                              ItemContainerStyle="{StaticResource AlbumItemStyle}"
                                              ItemTemplate="{StaticResource AlbumCardTemplate}"
                                              ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Hidden" 
                                              ItemsSource="{x:Bind LibraryVM.ExploreAlbums, Mode=OneWay}">
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="1" />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                    </GridView>
                                </StackPanel>

                                <!-- Recently Played -->
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <TextBlock x:Name="RecentlyPlayedTitle" Text="Recently Played" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        <HyperlinkButton Content="See All →" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnSeeAllRecentlyPlayed" FontSize="13" Opacity="0.8" UseSystemFocusVisuals="True" />
                                    </Grid>
                                    <GridView x:Name="RecentlyPlayedGridView" ItemClick="OnGenericAlbumClicked" IsItemClickEnabled="True" SelectionMode="None" 
                                              HorizontalAlignment="Stretch" VerticalAlignment="Top" Padding="0,0,0,8"
                                              ItemContainerStyle="{StaticResource AlbumItemStyle}"
                                              ItemTemplate="{StaticResource AlbumCardTemplate}"
                                              ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Hidden" 
                                              ItemsSource="{x:Bind LibraryVM.RecentPlayedAlbums, Mode=OneWay}">
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="1" />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                    </GridView>
                                </StackPanel>


                                <!-- Newly Added Releases -->
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <TextBlock x:Name="NewestTitle" Text="Newly Added Releases" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        <HyperlinkButton Content="See All →" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnSeeAllNewest" FontSize="13" Opacity="0.8" UseSystemFocusVisuals="True" />
                                    </Grid>
                                    <GridView x:Name="NewlyAddedGridView" ItemClick="OnGenericAlbumClicked" IsItemClickEnabled="True" SelectionMode="None" 
                                              HorizontalAlignment="Stretch" VerticalAlignment="Top" Padding="0,0,0,8"
                                              ItemContainerStyle="{StaticResource AlbumItemStyle}"
                                              ItemTemplate="{StaticResource AlbumCardTemplate}"
                                              ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Hidden" 
                                              ItemsSource="{x:Bind LibraryVM.NewestAlbums, Mode=OneWay}">
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="1" />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                    </GridView>
                                </StackPanel>



                                <!-- Recently Released Albums -->
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <TextBlock x:Name="RecentTitle" Text="Recently Released" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        <HyperlinkButton Content="See All →" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnSeeAllRecentReleases" FontSize="13" Opacity="0.8" UseSystemFocusVisuals="True" />
                                    </Grid>
                                    <GridView x:Name="RecentlyReleasedGridView" ItemClick="OnGenericAlbumClicked" IsItemClickEnabled="True" SelectionMode="None" 
                                              HorizontalAlignment="Stretch" VerticalAlignment="Top" Padding="0,0,0,8"
                                              ItemContainerStyle="{StaticResource AlbumItemStyle}"
                                              ItemTemplate="{StaticResource AlbumCardTemplate}"
                                              ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Hidden" 
                                              ItemsSource="{x:Bind LibraryVM.RecentReleasedAlbums, Mode=OneWay}">
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="1" />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                    </GridView>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                        <Grid x:Name="ArtistGrid" Visibility="Collapsed">
                        <Grid.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="20" />
                            </TransitionCollection>
                        </Grid.ChildrenTransitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Button x:Name="BackButton" Click="OnBackClicked" Margin="0,0,24,0" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Back" />
                            </Button>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                                <controls:ThumbnailView x:Name="ArtistDetailImage" Width="100" Height="100" ThumbnailCornerRadius="50" VerticalAlignment="Center" Visibility="Collapsed" DecodeWidth="200" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="ArtistDetailType" Text="ARTIST" FontSize="12" FontWeight="SemiBold" Opacity="0.6" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                    <TextBlock x:Name="ArtistDetailName" FontSize="48" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        
                        <GridView x:Name="AlbumsGridView" Grid.Row="1" ItemClick="OnAlbumClicked" IsItemClickEnabled="True">
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="150" Margin="12">
                                        <Border CornerRadius="8" Width="140" Height="140" Background="{ThemeResource AppControlBackgroundBrush}">
                                            <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="200" />
                                        </Border>
                                        <StackPanel Orientation="Vertical" Spacing="2" HorizontalAlignment="Center" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Artist}" FontSize="12" Opacity="0.8" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="•" FontSize="10" Opacity="0.5" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Year}" FontSize="12" Opacity="0.6" TextAlignment="Center" />
                                            </StackPanel>
                                            <Border Background="#55FFFFFF" CornerRadius="3" Padding="3,1" HorizontalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                                <TextBlock Text="E" FontSize="8" FontWeight="Bold" Foreground="White" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>

                    <Grid x:Name="AlbumGrid" Visibility="Collapsed">
                        <Grid.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="20" />
                            </TransitionCollection>
                        </Grid.ChildrenTransitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,0,0,16">
                            <Button x:Name="AlbumBackButton" Click="OnBackClicked" Margin="0,0,12,0" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Back" />
                            </Button>
                            <Border x:Name="AlbumDetailImageBorder" CornerRadius="8" Background="{ThemeResource AppControlBackgroundBrush}" Height="200" Width="200">
                                <controls:ThumbnailView x:Name="AlbumDetailImage" DecodeWidth="400" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="AlbumDetailTitle" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                    <Border x:Name="AlbumExplicitBadge" Visibility="Collapsed" Background="#55FFFFFF" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Margin="0,4,0,0">
                                        <TextBlock Text="E" FontSize="14" FontWeight="Bold" Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="AlbumDetailArtist" FontSize="14" Opacity="0.8" />
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                    <Button Content="Play Album" Click="OnPlayAlbumClicked" FontSize="14" Background="{ThemeResource SystemAccentColor}" Foreground="White" CornerRadius="21" Height="42" Padding="20,8" UseSystemFocusVisuals="True" />
                                    <Button Content="Shuffle" Click="OnShuffleAlbumClicked" FontSize="14" Background="Transparent" BorderBrush="{ThemeResource AppControlBorderBrush}" BorderThickness="1" CornerRadius="21" Height="42" Padding="20,8" UseSystemFocusVisuals="True" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <ListView x:Name="TracksListView" Grid.Row="1" ItemClick="OnTrackClicked" IsItemClickEnabled="True" ItemsSource="{Binding Source={StaticResource AlbumSongsSource}}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout Opening="OnTrackContextOpening">
                                                <MenuFlyoutItem Text="Play" Click="OnPlayMenuClicked" Icon="Play" />
                                                <MenuFlyoutItem Text="Add to Queue" Click="OnAddQueueMenuClicked" Icon="Add" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutSubItem Name="AddToPlaylistMenu" Text="Add to Playlist..." Icon="List" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TrackNumber}" FontSize="14" VerticalAlignment="Center" Opacity="0.5" />
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <Border Background="#55FFFFFF" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                                <TextBlock Text="E" FontSize="9" FontWeight="Bold" Foreground="White" />
                                            </Border>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <ToggleButton Tag="{Binding}" IsChecked="{Binding IsFavorite, Mode=OneWay}" Click="OnTrackFavoriteClicked" Background="Transparent" Padding="4" BorderThickness="0" UseSystemFocusVisuals="True">
                                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;" Loaded="OnFavoriteIconLoaded" Tag="{Binding}" FontSize="16" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                            </ToggleButton>
                                            <muxc:RatingControl MaxRating="5" Value="{Binding Rating, Mode=OneWay}" Tag="{Binding}" ValueChanged="OnTrackRatingChanged" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{Binding Duration}" FontSize="12" Opacity="0.6" VerticalAlignment="Center" HorizontalAlignment="Right" />

                                        <Button Grid.Column="4" Background="Transparent" BorderThickness="0" UseSystemFocusVisuals="True" VerticalAlignment="Center" HorizontalAlignment="Center" Click="OnMoreButtonClicked" Width="36" Height="36" Padding="0" Visibility="Visible">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" FontSize="14" Foreground="{ThemeResource AppTextForegroundBrush}" Opacity="0.6" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" Margin="0,12,0,8" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListView.GroupStyle>
                        </ListView>
                    </Grid>
                </Grid>

                <!-- Full Player View (Lyrics/Art only) -->
                <Grid x:Name="FullPlayerGrid" Visibility="Collapsed" Background="{ThemeResource OverlayBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <StackPanel x:Name="AlbumArtView" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="32">
                            <Grid x:Name="NowPlayingImageBorder" Width="500" Height="500">
                                <Border CornerRadius="20" BorderThickness="1" BorderBrush="{ThemeResource AppControlBorderBrush}" Background="{ThemeResource AppControlBackgroundBrush}">
                                    <controls:ThumbnailView x:Name="NowPlayingImage" DecodeWidth="800" />
                                </Border>
                            </Grid>
                        </StackPanel>

                        <Button x:Name="CollapseButton" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="40" Background="{ThemeResource AppControlBackgroundBrush}" Foreground="{ThemeResource AppTextForegroundBrush}" Width="48" Height="48" CornerRadius="24" BorderThickness="0" Click="OnCollapseClicked" UseSystemFocusVisuals="True" ToolTipService.ToolTip="Collapse Player">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;" FontSize="18" />
                        </Button>

                        <Grid x:Name="LyricsOverlay" Visibility="Collapsed" Padding="40,20,20,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="LyricsOverlayTitle" Text="Lyrics" FontSize="20" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,24" />
                                <ListView x:Name="LyricsListView" Grid.Row="1" SelectionMode="Single" ItemsSource="{x:Bind LyricsVM.Lines, Mode=OneTime}" SelectedIndex="{x:Bind LyricsVM.ActiveIndex, Mode=TwoWay}" IsItemClickEnabled="False" HorizontalAlignment="Stretch">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}" HorizontalAlignment="Center" TextAlignment="Center" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Queue -->
                    <Border x:Name="QueuePanel" Grid.Column="1" Background="{ThemeResource AppControlBackgroundBrush}" CornerRadius="16" Padding="24" Margin="0,24,24,24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="UP NEXT" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Click="OnClearQueueClick" Background="Transparent" BorderThickness="0" Padding="8" UseSystemFocusVisuals="True" ToolTipService.ToolTip="Clear upcoming queue">
                                    <SymbolIcon Symbol="Delete" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" />
                                </Button>
                            </Grid>
                            <ListView x:Name="QueueListView" Grid.Row="1" SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnQueueItemClick" ItemsSource="{x:Bind UpcomingQueue, Mode=OneWay}" CanDragItems="True" CanReorderItems="True" AllowDrop="True" DragItemsCompleted="OnQueueDragItemsCompleted">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="50" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" FontSize="12" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0" Opacity="0.5" />
                                            
                                            <Border CornerRadius="6" Background="{ThemeResource AppControlBackgroundBrush}" Grid.Column="1" Width="45" Height="45">
                                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="100" />
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" MaxLines="1" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}" />
                                                        <Border Background="{ThemeResource AppTertiaryTextForegroundBrush}" CornerRadius="3" Padding="3,1" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                                            <TextBlock Text="E" FontSize="8" FontWeight="Bold" Foreground="{ThemeResource AppBackgroundBrush}" />
                                                        </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Artist}" FontSize="10" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="3" Click="OnRemoveFromQueueClick" Tag="{Binding}" Background="Transparent" Padding="8" BorderThickness="0" UseSystemFocusVisuals="True" ToolTipService.ToolTip="Remove from queue">
                                                <SymbolIcon Symbol="Cancel" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>


