<Page
    x:Class="Opal.GenresPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:models="using:Opal"
    xmlns:converters="using:Opal.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <converters:StringFormatConverter x:Key="StringFormatConverter" />
        <DataTemplate x:Key="GenreTemplate" x:DataType="models:GenreModel">
            <Grid Width="200" Height="120" Margin="8">
                <Border CornerRadius="12" Background="{x:Bind BackgroundColor}" BorderThickness="1" BorderBrush="#22FFFFFF">
                    <Grid>
                        <!-- Subtle glass overlay -->
                        <Border CornerRadius="12" Background="#11FFFFFF" />
                        
                        <Grid Padding="20">
                            <StackPanel VerticalAlignment="Bottom" Spacing="2">
                                <TextBlock Text="{x:Bind Name}" FontSize="22" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind AlbumCount, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\} Albums'}" FontSize="12" Opacity="0.7" Foreground="White" FontWeight="SemiBold" />
                            </StackPanel>
                            
                            <!-- Large subtle icon in background -->
                            <SymbolIcon Symbol="Audio" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.15" Foreground="White" RenderTransformOrigin="0.5,0.5">
                                <SymbolIcon.RenderTransform>
                                    <CompositeTransform Rotation="15" TranslateX="10" TranslateY="-5" />
                                </SymbolIcon.RenderTransform>
                            </SymbolIcon>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="PageTitle.FontSize" Value="20" />
                        <Setter Target="HeaderPanel.Padding" Value="48,40,48,12" />
                        <Setter Target="GenreGrid.Padding" Value="40,0,40,40" />
                        <Setter Target="SearchContainer.Width" Value="160" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="HeaderPanel" Grid.Row="0" Padding="24,24,24,12">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="PageTitle" Text="Genres" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AppTextForegroundBrush}" />
                    <TextBlock Text="Browse your library by genre" FontSize="14" Opacity="0.7" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" />
                </StackPanel>
                <Grid x:Name="SearchContainer" HorizontalAlignment="Right" VerticalAlignment="Center" Width="220">
                    <TextBox x:Name="FilterBox" PlaceholderText="Search genres..." 
                             TextChanged="OnFilterOrSortChanged" 
                             VerticalAlignment="Center" 
                             Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" CornerRadius="18" Padding="32,6,12,6"
                             UseSystemFocusVisuals="True" />
                    <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Left" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.5" Foreground="{ThemeResource AppTextForegroundBrush}" />
                </Grid>
            </Grid>
        </StackPanel>

        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1" 
                    Visibility="{x:Bind GenreGrid.Items.Size, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='zero'}">
            <SymbolIcon Symbol="Filter" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" Width="64" Height="64" Opacity="0.3" />
            <TextBlock Text="No genres found" FontSize="18" FontWeight="SemiBold" Opacity="0.5" Margin="0,12,0,0" Foreground="{ThemeResource AppTextForegroundBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Try a different search term" FontSize="14" Opacity="0.4" Margin="0,4,0,0" Foreground="{ThemeResource AppTextForegroundBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <GridView x:Name="GenreGrid"
                  Grid.Row="1"
                  Padding="16"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="OnGenreClicked"
                  ItemTemplate="{StaticResource GenreTemplate}"
                  UseSystemFocusVisuals="True">
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20" />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>
    </Grid>
</Page>
