<Page
    x:Class="Opal.AlbumsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:controls="using:Opal.UI.Controls"
    xmlns:converters="using:Opal.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="AlbumItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="140" />
                <Setter Property="Margin" Value="8,0,8,20" />
            </Style>
            <Style x:Key="XboxAlbumItemStyle" TargetType="GridViewItem">
                <Setter Property="Width" Value="120" />
                <Setter Property="Margin" Value="6,0,6,12" />
            </Style>
            <converters:ExplicitStatusConverter x:Key="ExplicitStatusConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="24" Background="{ThemeResource AppBackgroundBrush}">


        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="48,40,48,48" />
                        <Setter Target="AlbumsGridView.Padding" Value="24,0,24,24" />
                        <Setter Target="AlbumsGridView.ItemContainerStyle" Value="{StaticResource XboxAlbumItemStyle}" />
                        <Setter Target="PageTitle.FontSize" Value="20" />
                        <Setter Target="ToolbarStack.Spacing" Value="12" />
                        <Setter Target="FilterBox.Width" Value="140" />
                        <Setter Target="SortByCombo.Width" Value="110" />
                        <Setter Target="YearFilterCombo.Width" Value="110" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="PageTitle" Grid.Column="0" Text="Albums" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Foreground="{ThemeResource AppTextForegroundBrush}" />

                <StackPanel x:Name="ToolbarStack" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="24">
                    <Grid x:Name="SearchContainer" Width="220">
                        <TextBox x:Name="FilterBox" PlaceholderText="Search albums..." 
                                 TextChanged="OnFilterOrSortChanged" 
                                 VerticalAlignment="Center" 
                                 Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" CornerRadius="18" Padding="32,6,12,6"
                                 UseSystemFocusVisuals="True"
                                 XYFocusRight="{x:Bind SortByCombo}" />
                        <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                  HorizontalAlignment="Left" Margin="12,0,0,0"
                                  VerticalAlignment="Center" Opacity="0.5"
                                  Foreground="{ThemeResource AppTextForegroundBrush}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Sort:" VerticalAlignment="Center" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" FontSize="13" />
                        <ComboBox x:Name="SortByCombo" Width="130" Height="36" SelectionChanged="OnFilterOrSortChanged" 
                                 Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" CornerRadius="18" Opacity="0.8"
                                 UseSystemFocusVisuals="True"
                                 XYFocusLeft="{x:Bind FilterBox}"
                                 XYFocusRight="{x:Bind YearFilterCombo}">
                            <ComboBoxItem Content="A-Z" IsSelected="True" />
                            <ComboBoxItem Content="Oldest First" />
                            <ComboBoxItem Content="Newest First" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" FontSize="13" />
                        <ComboBox x:Name="YearFilterCombo" Width="130" Height="36" SelectionChanged="OnFilterOrSortChanged" 
                                 Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" CornerRadius="18" Opacity="0.8"
                                 UseSystemFocusVisuals="True"
                                 XYFocusLeft="{x:Bind SortByCombo}">
                            <ComboBoxItem Content="All Years" IsSelected="True" />
                            <ComboBoxItem Content="2020 - Now" />
                            <ComboBoxItem Content="2010 - 2019" />
                            <ComboBoxItem Content="2000 - 2009" />
                            <ComboBoxItem Content="1990 - 1999" />
                            <ComboBoxItem Content="1980 - 1989" />
                            <ComboBoxItem Content="Before 1980" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <GridView x:Name="AlbumsGridView" Grid.Row="1" ItemClick="OnAlbumClicked" IsItemClickEnabled="True" ItemContainerStyle="{StaticResource AlbumItemStyle}" UseSystemFocusVisuals="True">
                <GridView.ItemContainerTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="20" />
                    </TransitionCollection>
                </GridView.ItemContainerTransitions>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2">
                            <Border CornerRadius="4" Background="{ThemeResource AppControlBackgroundBrush}" BorderThickness="0" Height="130" Width="130">
                                <controls:ThumbnailView SourceUrl="{Binding CoverUrl}" DecodeWidth="200" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppTextForegroundBrush}" MaxLines="1" />
                                <Border Background="{ThemeResource AppTertiaryTextForegroundBrush}" CornerRadius="4" Padding="4,1" VerticalAlignment="Center" Visibility="{Binding ExplicitStatus, Converter={StaticResource ExplicitStatusConverter}}">
                                    <TextBlock Text="E" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource AppBackgroundBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Artist}" FontSize="13" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource AppSecondaryTextForegroundBrush}" MaxLines="1"/>
                            <TextBlock Text="{Binding Year}" FontSize="12" Foreground="{ThemeResource AppTertiaryTextForegroundBrush}" />

                        </StackPanel>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
