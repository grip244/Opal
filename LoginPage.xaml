<Page
    x:Class="Opal.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Opal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DeviceStates">
                <VisualState x:Name="XboxState">
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="48,40,48,48" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="600" Spacing="16" Height="Auto">
            <TextBlock Text="Opal" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,12" Foreground="#4ECCA3"/>
            <TextBlock Text="Connect to your Music" FontSize="16" HorizontalAlignment="Center" Margin="0,-20,0,8" Opacity="0.8" Foreground="{ThemeResource AppTextForegroundBrush}" SelectionChanged="TextBlock_SelectionChanged"/>
            <TextBox x:Name="ServerTextBox" Header="Server URL" PlaceholderText="https://navidrome.example" FontSize="8" Height="47" KeyDown="OnLoginFieldKeyDown" TextChanged="ServerTextBox_TextChanged"/>
            <TextBox x:Name="UsernameTextBox" Header="Username" FontSize="8" Height="47" KeyDown="OnLoginFieldKeyDown"/>
            <PasswordBox x:Name="PasswordBox" Header="Password" FontSize="8" Height="47" KeyDown="OnLoginFieldKeyDown"/>
            <CheckBox x:Name="RememberMeCheckBox" Content="Remember Me" IsChecked="True" FontSize="8" Width="97" Height="12" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5" >
                <CheckBox.RenderTransform>
                    <CompositeTransform ScaleX="1"/>
                </CheckBox.RenderTransform>
            </CheckBox>
            <Button x:Name="ConnectButton" Content="Connect" HorizontalAlignment="Stretch" Height="24" FontSize="8" Background="#4ECCA3" Foreground="White" Click="OnConnectClicked" />
            <HyperlinkButton Content="Privacy Policy" FontSize="6"  Margin="0,0,0,0"  NavigateUri="https://darademsc.ddns.net/#privacy" HorizontalAlignment="Center" />
            <HyperlinkButton Content="Terms of Service" FontSize="6" Margin="0,-10,0,0" NavigateUri="https://darademsc.ddns.net/#tos" HorizontalAlignment="Center" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,-10,0,10">
                <ProgressRing x:Name="ProgressRing" IsActive="False" Width="36" Height="36" />
                <TextBlock x:Name="StatusText" FontSize="12" VerticalAlignment="Center" Width="250" Margin="0,0,30,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
